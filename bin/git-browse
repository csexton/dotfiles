#!/usr/bin/env ruby
repo = `git config --get remote.origin.url`.strip
abort "error: no remote 'origin' configured" if repo.empty?
branch = `git branch | sed -n '/\* /s///p'`.strip
repo_url = repo.sub(/^git@([^:]+):/, 'https://\1/').sub(/\.git$/, '')
repo_url = "#{repo_url}/tree/#{branch}"
`open #{repo_url}`
